#!/usr/bin/env bash

set -euo pipefail

REPO_ROOT="$(git rev-parse --show-toplevel)"
COMMIT_MESSAGE_FILE="${1:-}"

if [ -z "$COMMIT_MESSAGE_FILE" ]; then
    echo ""
    echo "  ERROR: commit message file path is required"
    echo ""
    exit 1
fi

bash "$REPO_ROOT/scripts/git/validate-commit-message.sh" --commit-msg-file "$COMMIT_MESSAGE_FILE"
