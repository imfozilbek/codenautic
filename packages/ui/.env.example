# API base URL for browser requests
VITE_API_URL=http://localhost:3001

# Browser Sentry SDK (optional, runtime)
VITE_SENTRY_DSN=
VITE_SENTRY_ENVIRONMENT=
VITE_SENTRY_RELEASE=
VITE_SENTRY_TRACES_SAMPLE_RATE=0.2
VITE_SENTRY_PROFILES_SAMPLE_RATE=0

# Sentry release upload (optional, used in vite build plugin)
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=
